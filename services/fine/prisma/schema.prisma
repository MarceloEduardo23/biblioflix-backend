// Fine Service — calcula multas por atraso (R$1/dia) a partir dos empréstimos
// do Loan Service, e registra pagamentos (fine_db).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id        String   @id @default(cuid())
  loanId    String
  userId    String
  amount    Float
  paidAt    DateTime @default(now())
}
